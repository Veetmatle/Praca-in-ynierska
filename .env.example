# ╔══════════════════════════════════════════════════════════╗
# ║  StudentApp — Environment Configuration                 ║
# ║  Copy to .env and fill in your values                    ║
# ╚══════════════════════════════════════════════════════════╝

# ── Database ──────────────────────────────────────────────
POSTGRES_DB=studentapp
POSTGRES_USER=studentapp
POSTGRES_PASSWORD=CHANGE_ME_strong_password_here
DB_PORT=5432

# ── JWT Authentication ────────────────────────────────────
# Generate with: openssl rand -base64 64
JWT_SECRET_KEY=CHANGE_ME_generate_with_openssl_rand_base64_64
JWT_ISSUER=StudentApp
JWT_AUDIENCE=StudentApp
JWT_ACCESS_EXPIRY=15
JWT_REFRESH_EXPIRY=7

# ── AES-GCM Encryption Key (for API keys in DB) ──────────
# Generate with: openssl rand -hex 32
ENCRYPTION_KEY=CHANGE_ME_generate_with_openssl_rand_hex_32

# ── Admin Seed Account ────────────────────────────────────
ADMIN_DEFAULT_PASSWORD=Admin123!

# ── Ports ─────────────────────────────────────────────────
BACKEND_PORT=8080
FRONTEND_PORT=3000

# ── OpenClaw Agent ────────────────────────────────────────
MAX_TOOL_ROUNDS=20
MAX_TOKENS=4096
AGENT_SESSION_TIMEOUT_MINUTES=10
MAX_CONCURRENT_TASKS=2

# ── UniScraper ────────────────────────────────────────────
SCRAPER_CACHE_TTL=60
